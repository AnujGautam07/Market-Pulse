# MarketPulse — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.

# --- PostgreSQL connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketpulse
DB_USER=
DB_PASSWORD=

# --- AI / LLM ---
GEMINI_API_KEY=

# --- Real data sources (set before running data/fetch_real_data.py) ---

# FRED (Federal Reserve Economic Data) — free key, no credit card
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI.org — 100 requests/day free tier, no credit card
# Register at: https://newsapi.org/register
NEWSAPI_KEY=
